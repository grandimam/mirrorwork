{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool": "Write",
          "if": "path matches 'activity/jobs/*.json'"
        },
        "command": "echo 'TRIGGER:fit-analysis:$CLAUDE_FILE_PATH'"
      },
      {
        "matcher": {
          "tool": "Write",
          "if": "path matches 'profile/*.json'"
        },
        "command": "echo 'TRIGGER:storybank-sync'"
      },
      {
        "matcher": {
          "tool": "Write",
          "if": "path matches 'sources/github/**/*.json'"
        },
        "command": "echo 'TRIGGER:storybank-sync'"
      }
    ]
  }
}
